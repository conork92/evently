# Supabase – same as other apps (e.g. HighgateAvenue). No region or password needed for the client.
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_ANON_KEY=your-anon-key

# Optional: Songkick "Add by link" uses scraping by default (no key needed). Set this to fall back to API if scrape fails.
